# Shared secret between Next.js and FastAPI (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=

# Supabase — use service role key (bypasses RLS; FastAPI is server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini
GEMINI_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# local: http://localhost:3000/api/google/callback
# production: https://lim-tuition.vercel.app/api/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_STUDENTS_FOLDER_ID=
GOOGLE_CALENDAR_ID=
# only needed for "My Python Syllabus" students
GOOGLE_LEC_TOPIC1_FILE_ID=

# CORS — comma-separated list of allowed frontend origins
# local: http://localhost:3000
# production: https://lim-tuition.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=tuition-agent
